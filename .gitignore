################################################################################
# Archivo .gitignore optimizado para proyectos .NET / Visual Studio
################################################################################

# Archivos y carpetas de configuración local de Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# Carpetas de compilación
bin/
obj/
[Bb]uild/
[Ll]ogs/

# Configuración de publicación
publish/
*.pubxml
*.pubxml.user

# Archivos de depuración y símbolos
*.pdb
*.mdb

# Archivos de compilación intermedios
*.dll
*.exe
*.cache
*.log

# Archivos de paquetes NuGet
*.nupkg
*.snupkg
packages/
*.nuspec

# Archivos de configuración de Rider/Resharper
.idea/
*.DotSettings.user

# Archivos de test y cobertura
TestResults/
*.coverage
*.coveragexml

# Archivos generados por herramientas
*.tmp
*.bak
*.swp

# Archivos de sistema
Thumbs.db
ehthumbs.db
Desktop.ini
/BackEnd/EG.ApiCore/bin/Debug/net10.0/EG.ApiCore.deps.json
