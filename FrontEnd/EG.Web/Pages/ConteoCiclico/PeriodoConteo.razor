@page "/conteociclico/periodo"
@using System.ComponentModel.DataAnnotations
@using EG.Web.Contracs
@using EG.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using System.Text
@using MiniExcelLibs
@using MudBlazor
@using System.Reflection

@inject NavigationManager NavigationManager
@inject IGenericCrudService<PeriodoConteoResponse> _service
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime _jsRuntime
@inject IGenericCrudService<TipoConteoResponse> _tipoConteoService
@inject IGenericCrudService<SucursalResponse> _sucursalService
@inject AuthenticationProviderJWT AuthProvider

<script>
    function downloadFile(base64Data, fileName, contentType) {
        try {
            const link = document.createElement('a');
            link.href = 'data:' + contentType + ';base64,' + base64Data;
            link.download = fileName;
            link.style.display = 'none';

            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        } catch (error) {
            console.error('Error downloading file:', error);
            throw error;
        }
    }
</script>

<MudContainer Class="d-flex flex-column" MaxWidth="MaxWidth.False" Style="height: 100vh;">
    <!-- Usando Card para el header -->
    <MudCard Elevation="1" Class="mb-4">
        <MudCardContent>
            <MudGrid Spacing="2" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudItem>
                    <MudStack Spacing="2">
                        <MudText Typo="Typo.h4"
                                 Color="Color.Primary"
                                 Style="font-weight: 600; display: flex; align-items: center; gap: 12px;">
                            <MudIcon Icon="@Icons.Material.Filled.Inventory"
                                     Color="Color.Primary"
                                     Size="Size.Large" />
                            Gestión de Periodos de Conteo
                        </MudText>
                        <MudText Typo="Typo.body2"
                                 Color="Color.Tertiary"
                                 Class="ml-6">
                            Administra y mantén los periodos de conteo cíclico del sistema
                        </MudText>
                    </MudStack>
                </MudItem>

                <MudItem>
                    <MudButtonGroup Variant="Variant.Filled" Color="Color.Primary">
                        @if (_canCreate)
                        {
                            <MudTooltip Text="Nuevo Periodo">
                                <MudButton StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="CrearPeriodo"
                                           Size="Size.Small" />
                            </MudTooltip>
                        }
                        <MudTooltip Text="Refrescar...">
                            <MudButton StartIcon="@Icons.Material.Filled.Refresh"
                                       OnClick="OnSearchInput"
                                       Size="Size.Small" />
                        </MudTooltip>
                    </MudButtonGroup>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>

    <MudPaper Elevation="2" Class="pa-4 rounded-lg">
        <!-- Filtros -->
        <MudGrid Spacing="2" Class="mb-4">
            @* <MudItem xs="12" sm="6" md="4">
                <MudSelect T="int?"
                           @bind-Value="selectedSucursalId"
                           Label="Filtrar por Sucursal"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           OnSelectedValuesChanged="OnSucursalChanged">
                    <MudSelectItem T="int?" Value="@null">Todas las sucursales</MudSelectItem>
                    @foreach (var sucursal in listadoSucursales)
                    {
                        <MudSelectItem T="int?" Value="@sucursal.PkidSucursal">@sucursal.Nombre</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="int?"
                           @bind-Value="selectedTipoConteoId"
                           Label="Filtrar por Tipo"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           OnSelectedValuesChanged="OnTipoConteoChanged">
                    <MudSelectItem T="int?" Value="@null">Todos los tipos</MudSelectItem>
                    @foreach (var tipo in listadoTiposConteo)
                    {
                        <MudSelectItem T="int?" Value="@tipo.PkidTipoConteo">@tipo.Nombre</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="4">
                <MudSelect T="bool?"
                           @bind-Value="selectedEstadoBool"
                           Label="Filtrar por Estado"
                           Variant="Variant.Outlined"
                           Clearable="true"
                           OnSelectedValuesChanged="OnEstadoChanged">
                    <MudSelectItem T="bool?" Value="@null">Todos los estados</MudSelectItem>
                    <MudSelectItem T="bool?" Value="true">Activo</MudSelectItem>
                    <MudSelectItem T="bool?" Value="false">Inactivo</MudSelectItem>
                </MudSelect>
            </MudItem> *@
        </MudGrid>

        <MudTable ServerData="LoadServerData"
                  RowsPerPage="@pageSize"
                  Page="@currentPage"
                  RowCount="@totalCount"
                  @ref="mudTableRef"
                  Dense="@dense"
                  Hover="@hover"
                  Loading="@loading"
                  ReadOnly="@ronly"
                  SortLabel="Ordenar por"
                  InitialSortDirection="SortDirection.Descending"
                  @bind-SelectedItem="selectedItem"
                  IsEditRowSwitchingBlocked="@blockSwitch"
                  ApplyButtonPosition="@applyButtonPosition"
                  EditButtonPosition="@editButtonPosition"
                  EditTrigger="@editTrigger">

            <ToolBarContent>
                <MudText Typo="Typo.h6">Lista de Periodos de Conteo</MudText>
                <MudSpacer />
                <!-- Botón de Exportar a Excel -->
                @if (_canExport)
                {
                    <MudTooltip Text="Exportar a Excel">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.FileDownload"
                                   OnClick="ExportarExcel"
                                   Size="Size.Small"
                                   Class="mr-2"
                                   Disabled="@loading">
                            @if (loading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Exportando...</span>
                            }
                            else
                            {
                                <span>Exportar Excel</span>
                            }
                        </MudButton>
                    </MudTooltip>
                }
                <MudTextField @bind-Value="searchString"
                              Placeholder="Buscar por código, nombre..."
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium"
                              Immediate="true"
                              @ref="txtSearch"
                              OnKeyUp="HandleKeyUp"
                              Class="mt-0">
                </MudTextField>
            </ToolBarContent>

            <HeaderContent>
                <MudTh>Acciones</MudTh>
                <MudTh><MudTableSortLabel SortLabel="CodigoPeriodo" T="PeriodoConteoResponse">Código</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="Nombre" T="PeriodoConteoResponse">Periodo</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="SucursalNombre" T="PeriodoConteoResponse">Sucursal</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="TipoConteoNombre" T="PeriodoConteoResponse">Tipo</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="FechaInicio" T="PeriodoConteoResponse">Fecha Inicio</MudTableSortLabel></MudTh>
                <MudTh>Progreso</MudTh>
                <MudTh>Estatus</MudTh>
            </HeaderContent>

            <RowTemplate>
                <MudTd>
                    <MudTooltip Text="Ver detalle">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Color="Color.Info"
                                       Size="Size.Small"
                                       OnClick="@(() => VerDetalle(context.Id))" />
                    </MudTooltip>

                    @if (_canUpdate)
                    {
                        <MudTooltip Text="Editar periodo">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           OnClick="@(() => EditarPeriodo(context.Id))" />
                        </MudTooltip>
                    }

                    @if (_canDelete)
                    {
                        <MudTooltip Text="Eliminar periodo">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => EliminarPeriodo(context.Id))" />
                        </MudTooltip>
                    }
                </MudTd>

                <MudTd DataLabel="Código">
                    <MudText Typo="Typo.body2" Class="font-weight-bold">@context.CodigoPeriodo</MudText>
                </MudTd>

                <MudTd DataLabel="Periodo">
                    <MudText Typo="Typo.body2">@context.Nombre</MudText>
                    @if (!string.IsNullOrEmpty(context.Descripcion))
                    {
                        <MudText Typo="Typo.caption" Class="text-secondary">@context.Descripcion</MudText>
                    }
                </MudTd>

                <MudTd DataLabel="Sucursal">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@context.SucursalNombre</MudChip>
                </MudTd>

                <MudTd DataLabel="Tipo">
                    <MudChip T="string" Size="Size.Small">@context.TipoConteoNombre</MudChip>
                </MudTd>

                <MudTd DataLabel="Fecha Inicio">
                    <MudText Typo="Typo.body2">
                        @context.FechaInicio.ToString("dd/MM/yyyy")
                        @if (context.FechaFin.HasValue)
                        {
                            <span> - @context.FechaFin.Value.ToString("dd/MM/yyyy")</span>
                        }
                    </MudText>
                </MudTd>

                <MudTd DataLabel="Progreso">
                    <div style="min-width: 120px;">
                        <MudText Typo="Typo.caption" Align="Align.Center">
                            @context.ArticulosConcluidos / @context.TotalArticulos artículos
                        </MudText>
                        <MudProgressLinear Value="@((double)(context.PorcentajeAvance ?? 0))"
                                           Color="GetProgressColor(context.PorcentajeAvance)"
                                           Size="Size.Small"
                                           Class="my-1" />
                        @if (context.ArticulosConDiferencia > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                ⚠ @context.ArticulosConDiferencia diferencias
                            </MudChip>
                        }
                    </div>
                </MudTd>

                <MudTd DataLabel="Estatus">
                    <MudChip T="string" Color="@GetEstatusColor(context.EstatusNombre)" Size="Size.Small">
                        @GetEstatusIcon(context.EstatusNombre) @context.EstatusNombre
                    </MudChip>
                </MudTd>
            </RowTemplate>

            <NoRecordsContent>
                <MudText>No se encontraron registros</MudText>
            </NoRecordsContent>

            <LoadingContent>
                <MudText>Cargando...</MudText>
            </LoadingContent>

            <PagerContent>
                <MudTablePager RowsPerPageString="Filas por página"
                               FirstPageIcon="@Icons.Material.Filled.FirstPage"
                               LastPageIcon="@Icons.Material.Filled.LastPage"
                               NextPageIcon="@Icons.Material.Filled.NavigateNext"
                               PreviousPageIcon="@Icons.Material.Filled.NavigateBefore"
                               PageSizeOptions="new int[] { 5, 10, 20, 50 }"
                               ShowFirstLastPage="true"
                               ShowPageSizeSelector="true"
                               ShowPaginationText="true"
                               PaginationTextFormat="Página {0} de {1}" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudContainer>

@code {
    private List<PeriodoConteoResponse> Elements = new();
    private List<TipoConteoResponse> listadoTiposConteo = new();
    private List<SucursalResponse> listadoSucursales = new();
    private int totalCount = 0;

    private bool _isInitialized = false;
    private bool dense = true;
    private bool hover = true;
    private bool ronly = true;
    private bool blockSwitch = false;

    private bool _hasAccess = false;
    // Permisos específicos para esta página
    private bool _canView = false;
    private bool _canCreate = false;
    private bool _canUpdate = false;
    private bool _canDelete = false;
    private bool _canExport = false;

    private PeriodoConteoResponse selectedItem = new();
    private MudTable<PeriodoConteoResponse> mudTableRef = new();
    private MudTextField<string> txtSearch = new();

    private string searchString = string.Empty;
    private int? selectedSucursalId;
    private int? selectedTipoConteoId;
    private bool? selectedEstadoBool; // Cambiado de string? a bool?
    private bool loading = true;
    private int currentPage = 0;
    private int pageSize = 10;
    private CancellationTokenSource searchCts = new();

    private TableApplyButtonPosition applyButtonPosition = TableApplyButtonPosition.End;
    private TableEditButtonPosition editButtonPosition = TableEditButtonPosition.End;
    private TableEditTrigger editTrigger = TableEditTrigger.RowClick;

    private SortDirection sortDirection;
    private string sortLabel = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await VerificarPermisos();
        if (_canView)
        {
            await CargarCatalogos();
        }
        loading = false;
    }

    private async Task VerificarPermisos()
    {
        try
        {
            // Verificar permisos usando AuthenticationProviderJWT
            _canView = AuthProvider.HasPermission("conteocliclico", "periodo", "view");
            _canCreate = AuthProvider.HasPermission("conteocliclico", "periodo", "new");
            _canUpdate = AuthProvider.HasPermission("conteocliclico", "periodo", "update");
            _canDelete = AuthProvider.HasPermission("conteocliclico", "periodo", "delete");
            _canExport = AuthProvider.HasPermission("conteocliclico", "periodo", "export");

            _hasAccess = _canView;

            if (!_hasAccess)
            {
                Snackbar.Add("No tienes permisos para acceder a esta página", Severity.Warning);
                await Task.Delay(1000);
                NavigationManager.NavigateTo("/", forceLoad: true);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al verificar permisos: {ex.Message}", Severity.Error);
            NavigationManager.NavigateTo("/", forceLoad: true);
        }
    }

    private async Task CargarCatalogos()
    {
        try
        {
            // Cargar tipos de conteo
            var tiposResponse = await _tipoConteoService.GetAllAsync();
            if (tiposResponse?.Success == true && tiposResponse.Items != null)
            {
                listadoTiposConteo = tiposResponse.Items.ToList();
            }

            // Cargar sucursales
            var sucursalesResponse = await _sucursalService.GetAllAsync();
            if (sucursalesResponse?.Success == true && sucursalesResponse.Items != null)
            {
                listadoSucursales = sucursalesResponse.Items.ToList();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar catálogos: {ex.Message}", Severity.Error);
        }
    }

    private async Task<TableData<PeriodoConteoResponse>> LoadServerData(TableState state, CancellationToken cancellationToken)
    {
        if (!_canView)
        {
            return new TableData<PeriodoConteoResponse>
            {
                Items = new List<PeriodoConteoResponse>(),
                TotalItems = 0
            };
        }

        loading = true;
        StateHasChanged();

        try
        {
            currentPage = state.Page + 1;
            pageSize = state.PageSize;
            sortLabel = state.SortLabel ?? "FechaInicio";
            sortDirection = state.SortDirection;

            var filters = BuildFilterString();

            var response = await _service.GetAllPaginadoAsync(
                currentPage,
                pageSize,
                searchString,
                sortLabel,
                sortDirection,
                !string.IsNullOrEmpty(filters) ? new Dictionary<string, object> { { "filter", filters } } : null
            );

            if (response != null && response.Success)
            {
                Elements = response.Items?.ToList() ?? new();
                totalCount = response.TotalCount;
            }
            else
            {
                Elements = new List<PeriodoConteoResponse>();
                totalCount = 0;
                if (response?.Message != null)
                    Snackbar.Add(response.Message, Severity.Error);
            }

            return new TableData<PeriodoConteoResponse>
            {
                Items = Elements,
                TotalItems = totalCount
            };
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar periodos: {ex.Message}", Severity.Error);
            return new TableData<PeriodoConteoResponse>
            {
                Items = new List<PeriodoConteoResponse>(),
                TotalItems = 0
            };
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private string BuildFilterString()
    {
        var filters = new List<string>();

        if (selectedSucursalId.HasValue)
            filters.Add($"SucursalId=={selectedSucursalId}");

        if (selectedTipoConteoId.HasValue)
            filters.Add($"TipoConteoId=={selectedTipoConteoId}");

        if (selectedEstadoBool.HasValue)
            filters.Add($"Activo=={selectedEstadoBool.Value}"); // Usar el valor booleano directamente

        return string.Join(" AND ", filters);
    }

    private async void OnSearchInput()
    {
        searchCts?.Cancel();
        searchCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(500, searchCts.Token);

            if (!searchCts.Token.IsCancellationRequested && mudTableRef != null)
            {
                currentPage = 0;
                await mudTableRef.ReloadServerData();
            }
        }
        catch (TaskCanceledException)
        {
            // Búsqueda cancelada
        }
    }

    private async Task OnSucursalChanged(int? value)
    {
        selectedSucursalId = value;
        currentPage = 0;
        if (mudTableRef != null)
            await mudTableRef.ReloadServerData();
    }

    private async Task OnTipoConteoChanged(int? value)
    {
        selectedTipoConteoId = value;
        currentPage = 0;
        if (mudTableRef != null)
            await mudTableRef.ReloadServerData();
    }

    // Cambiado para recibir bool?
    private async Task OnEstadoChanged(bool? value)
    {
        selectedEstadoBool = value;
        currentPage = 0;
        if (mudTableRef != null)
            await mudTableRef.ReloadServerData();
    }

    private async void HandleKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            currentPage = 0;
            await mudTableRef.ReloadServerData();
        }
    }

    private void VerDetalle(int id)
    {
        NavigationManager.NavigateTo($"/conteociclico/periodo/{id}");
    }

    private async Task CrearPeriodo()
    {
        if (!_canCreate)
        {
            Snackbar.Add("No tienes permisos para crear periodos", Severity.Warning);
            return;
        }

        try
        {
            var parameters = new DialogParameters
            {
                ["IsEdit"] = false,
                ["ItemId"] = 0
            };

            var options = new DialogOptions
            {
                CloseButton = true,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
                Position = DialogPosition.Center,
                NoHeader = false,
            };

            var dialog = await DialogService.ShowAsync<PeriodoConteoDialog>("Nuevo Periodo de Conteo", parameters, options);
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                currentPage = 0;
                await mudTableRef.ReloadServerData();
                Snackbar.Add("Periodo creado correctamente", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Ocurrió un error: " + ex.Message, Severity.Error);
        }
    }

    private async Task EditarPeriodo(int id)
    {
        if (!_canUpdate)
        {
            Snackbar.Add("No tienes permisos para editar periodos", Severity.Warning);
            return;
        }

        try
        {
            var parameters = new DialogParameters
            {
                ["IsEdit"] = true,
                ["ItemId"] = id
            };

            var options = new DialogOptions
            {
                CloseButton = true,
                MaxWidth = MaxWidth.Medium,
                FullWidth = true,
            };

            var dialog = await DialogService.ShowAsync<PeriodoConteoDialog>("Editar Periodo de Conteo", parameters, options);
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                await mudTableRef.ReloadServerData();
                Snackbar.Add("Periodo actualizado correctamente", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al editar periodo: " + ex.Message, Severity.Error);
        }
    }

    private async Task EliminarPeriodo(int id)
    {
        if (!_canDelete)
        {
            Snackbar.Add("No tienes permisos para eliminar periodos", Severity.Warning);
            return;
        }

        try
        {
            var parameters = new DialogParameters
            {
                ["ItemId"] = id,
                ["ItemName"] = await GetItemName(id)
            };

            var options = new DialogOptions
            {
                CloseButton = true,
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
            };

            //var dialog = await DialogService.ShowAsync<EliminarPeriodoDialog>("Eliminar Periodo", parameters, options);
            //var result = await dialog.Result;

            // if (!result!.Canceled)
            // {
            //     if (Elements.Count == 1 && currentPage > 0)
            //     {
            //         currentPage--;
            //     }
            //     await mudTableRef.ReloadServerData();
            //     Snackbar.Add("Periodo eliminado correctamente", Severity.Success);
            // }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al eliminar periodo: " + ex.Message, Severity.Error);
        }
    }

    private async Task<string> GetItemName(int id)
    {
        try
        {
            var response = await _service.GetByIdAsync(id);
            return response?.Data?.CodigoPeriodo ?? "el periodo";
        }
        catch
        {
            return "el periodo";
        }
    }

    private async Task ExportarExcel()
    {
        if (!_canExport)
        {
            Snackbar.Add("No tienes permisos para exportar datos", Severity.Warning);
            return;
        }

        try
        {
            loading = true;
            StateHasChanged();

            var filters = BuildFilterString();

            var response = await _service.GetAllPaginadoAsync(
                -1,
                pageSize,
                searchString,
                sortLabel,
                sortDirection,
                !string.IsNullOrEmpty(filters) ? new Dictionary<string, object> { { "filter", filters } } : null
            );

            if (response == null || !response.Success || response.Items == null || !response.Items.Any())
            {
                Snackbar.Add(response?.Message ?? "No hay datos para exportar", Severity.Warning);
                return;
            }

            Elements = response.Items.ToList();

            var excelData = Elements.Select(p => new
            {
                Código = p.CodigoPeriodo,
                Periodo = p.Nombre,
                Descripción = p.Descripcion,
                Sucursal = p.SucursalNombre,
                Tipo = p.TipoConteoNombre,
                Estatus = p.EstatusNombre,
                Fecha_Inicio = p.FechaInicio.ToString("dd/MM/yyyy"),
                Fecha_Fin = p.FechaFin?.ToString("dd/MM/yyyy"),
                Total_Artículos = p.TotalArticulos,
                Conteos_Concluidos = p.ArticulosConcluidos,
                Conteos_Pendientes = p.ArticulosPendientes,
                Diferencias = p.ArticulosConDiferencia,
                Avance = $"{p.PorcentajeAvance}%",
                Responsable = p.ResponsableNombre,
                Supervisor = p.SupervisorNombre,
                Activo = p.Activo ? "Sí" : "No"
            }).ToList();

            using var memoryStream = new MemoryStream();
            await memoryStream.SaveAsAsync(excelData);

            var fileBytes = memoryStream.ToArray();
            var base64 = Convert.ToBase64String(fileBytes);

            await _jsRuntime.InvokeVoidAsync("downloadFile", base64,
                $"PeriodosConteo_{DateTime.Now:yyyyMMddHHmmss}.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");

            Snackbar.Add($"Exportación exitosa: {Elements.Count} registros", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al exportar: {ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private Color GetProgressColor(decimal? porcentaje)
    {
        if (!porcentaje.HasValue) return Color.Default;

        return porcentaje.Value switch
        {
            >= 75 => Color.Success,
            >= 50 => Color.Info,
            >= 25 => Color.Warning,
            _ => Color.Error
        };
    }

    private Color GetEstatusColor(string estatus)
    {
        return estatus?.ToLower() switch
        {
            "pendiente" => Color.Warning,
            "en proceso" => Color.Info,
            "completado" => Color.Success,
            "cerrado" => Color.Default,
            _ => Color.Default
        };
    }

    private string GetEstatusIcon(string estatus)
    {
        return estatus?.ToLower() switch
        {
            "pendiente" => Icons.Material.Filled.Schedule,
            "en proceso" => Icons.Material.Filled.Autorenew,
            "completado" => Icons.Material.Filled.CheckCircle,
            "cerrado" => Icons.Material.Filled.Lock,
            _ => Icons.Material.Filled.Help
        };
    }

    public void Dispose()
    {
        searchCts?.Cancel();
        searchCts?.Dispose();
        GC.SuppressFinalize(this);
    }
}