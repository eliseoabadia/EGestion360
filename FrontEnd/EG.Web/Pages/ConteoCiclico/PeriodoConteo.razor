@page "/conteociclico/periodo"
@using EG.Web.Models.ConteoCiclico
@using EG.Web.Pages.Shared
@using EG.Web.Shared
@using EG.Web.Contracs.Configuration
@inherits BaseCrudPage<PeriodoConteoResponse, PeriodoConteoResponse>
@* @inject IPeriodoConteoService PeriodoConteoService *@

<AccessVerification IsInitialized="@IsInitialized"
                    HasAccess="@HasAccess"
                    NavigateToHome="NavigateToHome">
    <MudContainer Class="px-2 d-flex flex-column" MaxWidth="MaxWidth.False" Style="height: 100vh;">
        <PageHeader Title="Gestión de Periodos de Conteo"
                    Subtitle="Administra y mantén los periodos de conteo cíclico del sistema"
                    Icon="@Icons.Material.Filled.Inventory"
                    CanCreate="@CanCreate"
                    OnCreate="CreateItem"
                    OnRefresh="() => table.ReloadData()" />

        <!-- Leyenda del flujo de estatus -->
        <MudPaper Class="pa-3 mb-3" Elevation="0" Style="border-radius:8px; border:1px solid var(--mud-palette-divider);">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">Flujo de Estatus</MudText>
            <div class="d-flex align-center gap-1 flex-wrap">
                <MudChip T="string" Icon="@Icons.Material.Filled.Schedule" Color="Color.Warning" Size="Size.Small" Variant="Variant.Outlined">Pendiente</MudChip>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                <MudChip T="string" Icon="@Icons.Material.Filled.Autorenew" Color="Color.Info" Size="Size.Small" Variant="Variant.Outlined">En Proceso</MudChip>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                <MudChip T="string" Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" Variant="Variant.Outlined">Completado</MudChip>
                <MudIcon Icon="@Icons.Material.Filled.ArrowForward" Size="Size.Small" Color="Color.Default" />
                <MudChip T="string" Icon="@Icons.Material.Filled.Lock" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">Cerrado</MudChip>
            </div>
        </MudPaper>

        <GenericTable TItem="PeriodoConteoResponse"
                      @ref="table"
                      Title="Lista de Periodos de Conteo"
                      SearchPlaceholder="Buscar por código, nombre..."
                      ShowExportButton="@CanExport"
                      ServerDataFunc="LoadServerData"
                      ExportFunc="ExportToExcel"
                      SearchString="@SearchString"
                      SearchStringChanged="(s) => SearchString = s"
                      OnSearch="OnSearch">

            <Header>
                <MudTh>Acciones</MudTh>
                <MudTh><MudTableSortLabel SortLabel="CodigoPeriodo" T="PeriodoConteoResponse">Código</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="Nombre" T="PeriodoConteoResponse">Periodo</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="SucursalNombre" T="PeriodoConteoResponse">Sucursal</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="TipoConteoNombre" T="PeriodoConteoResponse">Tipo</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="FechaInicio" T="PeriodoConteoResponse">Fecha Inicio</MudTableSortLabel></MudTh>
                <MudTh>Progreso</MudTh>
                <MudTh>Estatus</MudTh>
                <MudTh>Flujo</MudTh>
            </Header>

            <Row Context="periodo">
                <MudTd>
                    <MudTooltip Text="Ver detalle">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                       Color="Color.Info"
                                       Size="Size.Small"
                                       OnClick="@(() => VerDetalle(periodo.Id))" />
                    </MudTooltip>
                    <MudTooltip Text="Editar periodo">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Visible="@CanUpdate"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => EditItem(periodo.Id))" />
                    </MudTooltip>
                    <MudTooltip Text="Eliminar periodo">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Visible="@CanDelete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => DeleteItem(periodo.Id))" />
                    </MudTooltip>
                </MudTd>

                <MudTd DataLabel="Código">
                    <MudText Typo="Typo.body2" Class="font-weight-bold">@periodo.CodigoPeriodo</MudText>
                </MudTd>

                <MudTd DataLabel="Periodo">
                    <MudText Typo="Typo.body2">@periodo.Nombre</MudText>
                    @if (!string.IsNullOrEmpty(periodo.Descripcion))
                    {
                        <MudText Typo="Typo.caption" Class="text-secondary">@periodo.Descripcion</MudText>
                    }
                </MudTd>

                <MudTd DataLabel="Sucursal">
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@periodo.SucursalNombre</MudChip>
                </MudTd>

                <MudTd DataLabel="Tipo">
                    <MudChip T="string" Size="Size.Small">@periodo.TipoConteoNombre</MudChip>
                </MudTd>

                <MudTd DataLabel="Fecha Inicio">
                    <MudText Typo="Typo.body2">
                        @periodo.FechaInicio.ToString("dd/MM/yyyy")
                        @if (periodo.FechaFin.HasValue)
                        {
                            <span> - @periodo.FechaFin.Value.ToString("dd/MM/yyyy")</span>
                        }
                    </MudText>
                </MudTd>

                <MudTd DataLabel="Progreso">
                    <div style="min-width: 120px;">
                        <MudText Typo="Typo.caption" Align="Align.Center">
                            @periodo.ArticulosConcluidos / @periodo.TotalArticulos artículos
                        </MudText>
                        <MudProgressLinear Value="@((double)(periodo.PorcentajeAvance ?? 0))"
                                           Color="GetProgressColor(periodo.PorcentajeAvance)"
                                           Size="Size.Small"
                                           Class="my-1" />
                        @if (periodo.ArticulosConDiferencia > 0)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                ⚠ @periodo.ArticulosConDiferencia diferencias
                            </MudChip>
                        }
                    </div>
                </MudTd>

                <MudTd DataLabel="Estatus">
                    <MudChip T="string" Color="@GetEstatusColor(periodo.EstatusNombre)" Size="Size.Small">
                        <MudIcon Icon="@GetEstatusIcon(periodo.EstatusNombre)" Size="Size.Small" Class="mr-1" />
                        @periodo.EstatusNombre
                    </MudChip>
                </MudTd>

                <!-- Columna de flujo de estatus -->
                <MudTd DataLabel="Flujo">
                    @if (CanUpdate && GetTransicionesPermitidas(periodo.EstatusId) is var transiciones && transiciones.Any())
                    {
                        <MudMenu Icon="@Icons.Material.Filled.SwapHoriz"
                                 Color="Color.Secondary"
                                 Size="Size.Small"
                                 Dense="true"
                                 Variant="Variant.Outlined"
                                 Title="Cambiar estatus">
                            @foreach (var (estatusId, label, icon, color) in transiciones)
                            {
                                var localEstatusId = estatusId;
                                var localPeriodo = periodo;
                                <MudMenuItem OnClick="@(async () => await CambiarEstatus(localPeriodo, localEstatusId))">
                                    <MudIcon Icon="@icon" Color="@color" Size="Size.Small" Class="mr-2" />
                                    @label
                                </MudMenuItem>
                            }
                        </MudMenu>
                    }
                    else if (!CanUpdate)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Tertiary">—</MudText>
                    }
                    else
                    {
                        <MudTooltip Text="No hay transiciones disponibles">
                            <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Tertiary" />
                        </MudTooltip>
                    }
                </MudTd>
            </Row>
        </GenericTable>
    </MudContainer>
</AccessVerification>

@code {
    private GenericTable<PeriodoConteoResponse> table = null!;

    protected override string ModuleName => "conteocliclico";
    protected override string SubModuleName => "periodo";

    protected override Type CreateDialogType => typeof(PeriodoConteoDialog);
    protected override Type EditDialogType => typeof(PeriodoConteoDialog);
    protected override Type DeleteDialogType => typeof(DeleteDialog<PeriodoConteoResponse>);

    protected override string GetDefaultSortLabel() => "FechaInicio";

    // ─────────────────────────────────────────────
    // Flujo de Estatus
    // ─────────────────────────────────────────────

    /// <summary>
    /// ID → Nombre canónico para comparaciones
    /// 1 = Pendiente, 2 = En Proceso, 3 = Completado, 4 = Cerrado
    /// </summary>
    private static readonly Dictionary<int, string> EstatusNombres = new()
    {
        { 1, "Pendiente" },
        { 2, "En Proceso" },
        { 3, "Completado" },
        { 4, "Cerrado" }
    };

    /// <summary>
    /// Devuelve la lista de (estatusId, etiqueta, icono, color) a los que puede avanzar el periodo.
    /// Reglas del flujo (líneas sólidas + punteadas del diagrama):
    ///   Pendiente   → En Proceso, Cerrado (atajo)
    ///   En Proceso  → Completado, Cerrado (atajo)
    ///   Completado  → Cerrado
    ///   Cerrado     → (ninguno — estado final)
    /// </summary>
    private List<(int estatusId, string label, string icon, Color color)> GetTransicionesPermitidas(int actualEstatusId)
        => actualEstatusId switch
        {
            1 => new List<(int, string, string, Color)>
            {
                (2, "Iniciar → En Proceso",   Icons.Material.Filled.PlayArrow,       Color.Info),
                (4, "Cerrar directamente",      Icons.Material.Filled.LockOpen,        Color.Default),
            },
            2 => new List<(int, string, string, Color)>
            {
                (3, "Completar",               Icons.Material.Filled.CheckCircle,     Color.Success),
                (4, "Cerrar directamente",      Icons.Material.Filled.LockOpen,        Color.Default),
            },
            3 => new List<(int, string, string, Color)>
            {
                (4, "Cerrar periodo",           Icons.Material.Filled.Lock,            Color.Default),
            },
            _ => new List<(int, string, string, Color)>()
        };

    private async Task CambiarEstatus(PeriodoConteoResponse periodo, int nuevoEstatusId)
    {
        try
        {
            // var response = await PeriodoConteoService.CambiarEstatusAsync(periodo.Id, nuevoEstatusId);
            // if (response?.Success == true)
            // {
            //     var nombreNuevo = EstatusNombres.GetValueOrDefault(nuevoEstatusId, "nuevo estatus");
            //     Snackbar.Add($"✅ Periodo '{periodo.CodigoPeriodo}' cambiado a: {nombreNuevo}", Severity.Success);
            //     await table.ReloadData();
            // }
            // else
            // {
            //    Snackbar.Add(response?.Message ?? "No se pudo cambiar el estatus", Severity.Warning);
            // }
            Snackbar.Add("Por implementar", Severity.Warning);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cambiar estatus: {ex.Message}", Severity.Error);
        }
    }

    // ─────────────────────────────────────────────
    // Helpers de la tabla
    // ─────────────────────────────────────────────

    protected override IEnumerable<object> MapToExcelData(IEnumerable<PeriodoConteoResponse> items)
    {
        return items.Select(p => new
        {
            Código = p.CodigoPeriodo,
            Periodo = p.Nombre,
            Descripción = p.Descripcion,
            Sucursal = p.SucursalNombre,
            Tipo = p.TipoConteoNombre,
            Estatus = p.EstatusNombre,
            Fecha_Inicio = p.FechaInicio.ToString("dd/MM/yyyy"),
            Fecha_Fin = p.FechaFin?.ToString("dd/MM/yyyy"),
            Total_Artículos = p.TotalArticulos,
            Conteos_Concluidos = p.ArticulosConcluidos,
            Conteos_Pendientes = p.ArticulosPendientes,
            Diferencias = p.ArticulosConDiferencia,
            Avance = $"{p.PorcentajeAvance}%",
            Responsable = p.ResponsableNombre,
            Supervisor = p.SupervisorNombre,
            Activo = p.Activo ? "Sí" : "No"
        });
    }

    protected override async Task<string> GetItemNameForDelete(int id)
    {
        try
        {
            var response = await Service.GetByIdAsync(id);
            return response?.Data?.CodigoPeriodo ?? "el periodo";
        }
        catch
        {
            return "el periodo";
        }
    }

    protected override async Task ReloadData()
    {
        if (table != null)
        {
            await table.ReloadData();
            StateHasChanged();
        }
    }

    protected override async Task DeleteItem(int id)
    {
        if (!CanDelete)
        {
            Snackbar.Add("No tienes permisos para eliminar", Severity.Warning);
            return;
        }

        var response = await Service.GetByIdAsync(id);
        var itemName = response?.Data?.CodigoPeriodo ?? "el periodo";

        var parameters = new DialogParameters
        {
            ["Id"] = id,
            ["ItemName"] = itemName,
            ["DeleteFunc"] = new Func<int, Task<bool>>(async (deleteId) =>
            {
                var deleteResponse = await Service.DeleteAsync(deleteId);
                if (deleteResponse?.Success == true)
                {
                    Snackbar.Add(deleteResponse.Message ?? "Periodo eliminado correctamente", Severity.Success);
                    await table.ReloadData();
                    return true;
                }
                else
                {
                    Snackbar.Add(deleteResponse?.Message ?? "Error al eliminar", Severity.Error);
                    return false;
                }
            })
        };

        var dialog = await DialogService.ShowAsync(DeleteDialogType, $"Eliminar {SubModuleName}", parameters,
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });

        await dialog.Result;
    }

    private void VerDetalle(int id)
    {
        NavigationManager.NavigateTo($"/conteociclico/periodo/{id}");
    }

    private Color GetProgressColor(decimal? porcentaje)
    {
        if (!porcentaje.HasValue) return Color.Default;

        return porcentaje.Value switch
        {
            >= 75 => Color.Success,
            >= 50 => Color.Info,
            >= 25 => Color.Warning,
            _     => Color.Error
        };
    }

    private Color GetEstatusColor(string estatus)
    {
        return estatus?.ToLower() switch
        {
            "pendiente"  => Color.Warning,
            "en proceso" => Color.Info,
            "completado" => Color.Success,
            "cerrado"    => Color.Default,
            _            => Color.Default
        };
    }

    private string GetEstatusIcon(string estatus)
    {
        return estatus?.ToLower() switch
        {
            "pendiente"  => Icons.Material.Filled.Schedule,
            "en proceso" => Icons.Material.Filled.Autorenew,
            "completado" => Icons.Material.Filled.CheckCircle,
            "cerrado"    => Icons.Material.Filled.Lock,
            _            => Icons.Material.Filled.Help
        };
    }
}