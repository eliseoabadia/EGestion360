@using EG.Web.Models.ConteoCiclico
@using EG.Web.Contracs.ConteoCiclico
@inject IConteoCiclicoService ConteoCiclicoService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddCircle" Color="Color.Info" Class="mr-2" />
            Registrar Conteo
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Class="mb-4">
            Artículo: <strong>@Articulo.CodigoArticulo - @Articulo.DescripcionArticulo</strong><br />
            Existencia en sistema: <strong>@Articulo.ExistenciaSistema.ToString("N2")</strong><br />
            Conteo número: <strong>@(Articulo.ConteosRealizados + 1) de @Articulo.MaximoConteosPorArticulo</strong>
        </MudText>

        <MudTextField @bind-Value="model.CantidadContada"
                      Label="Cantidad contada *"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Adornment="Adornment.End"
                      AdornmentText="unidades"
                      Required="true"
                      For="@(() => model.CantidadContada)" />

        <MudTextField @bind-Value="model.Observaciones"
                      Label="Observaciones"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Lines="3" />

        <MudCheckBox T="bool"
                     @bind-Checked="model.EsReconteo"
                     Label="Es reconteo"
                     Color="Color.Info" />

        @if (EsPrimerConteo)
        {
            <MudAlert Severity="Severity.Info" Class="mt-3">
                Al ser el primer conteo, esta cantidad se considerará como existencia final temporal.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Guardar" Disabled="!EsValido">Guardar Conteo</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ArticuloConteoResponse Articulo { get; set; } = null!;
    [Parameter] public bool EsReconteo { get; set; } = false;

    private class RegistroModel
    {
        public decimal CantidadContada { get; set; }
        public string? Observaciones { get; set; }
        public bool EsReconteo { get; set; }
    }
    private RegistroModel model = new();
    private bool EsPrimerConteo => Articulo.ConteosRealizados == 0;
    private bool EsValido => model.CantidadContada > 0;

    protected override void OnInitialized() => model.EsReconteo = EsReconteo;

    private void Cancelar() => MudDialog.Cancel();

    private async Task Guardar()
    {
        try
        {
            var request = new RegistrarConteoRequest
            {
                ArticuloConteoId = Articulo.Id,
                CantidadContada = model.CantidadContada,
                Observaciones = model.Observaciones,
                EsReconteo = model.EsReconteo
            };
            var result = await ConteoCiclicoService.RegistrarConteoAsync(request);
            if (result.Success)
            {
                Snackbar.Add(result.Message, Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else Snackbar.Add(result.Message, Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }
}