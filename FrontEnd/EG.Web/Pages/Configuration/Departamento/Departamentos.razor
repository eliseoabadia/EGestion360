@page "/configuracion/departamentos"
@using EG.Web.Models.Configuration
@using EG.Web.Pages.Shared
@using EG.Web.Shared
@inherits BaseCrudPage<DepartamentoResponse, DepartamentoResponse>

<AccessVerification IsInitialized="@IsInitialized"
                    HasAccess="@HasAccess"
                    NavigateToHome="NavigateToHome">
    <MudContainer Class="px-2 d-flex flex-column" MaxWidth="MaxWidth.False" Style="height: 100vh;">
        <PageHeader Title="Gestión de Departamentos"
                    Subtitle="Administra y mantén el registro de departamentos del sistema"
                    Icon="@Icons.Material.Filled.Domain"
                    CanCreate="@CanCreate"
                    OnCreate="CreateItem"
                    OnRefresh="() => table.ReloadData()" />

        <GenericTable TItem="DepartamentoResponse"
                      @ref="table"
                      Title="Lista de Departamentos"
                      SearchPlaceholder="Buscar por nombre..."
                      ShowExportButton="@CanExport"
                      ServerDataFunc="LoadServerData"
                      ExportFunc="ExportToExcel"
                      SearchString="@SearchString"
                      SearchStringChanged="(s) => SearchString = s"
                      OnSearch="OnSearch">

            <Header>
                <MudTh>Acciones</MudTh>
                <MudTh><MudTableSortLabel SortLabel="PkidDepartamento" T="DepartamentoResponse">ID</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="DepartamentoNombre" T="DepartamentoResponse">Nombre</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortLabel="EmpresaNombre" T="DepartamentoResponse">Empresa</MudTableSortLabel></MudTh>
                <MudTh>Estado</MudTh>
            </Header>

            <Row Context="departamento">
                <MudTd>
                    <MudTooltip Text="Editar departamento">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Visible="@CanUpdate"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => EditItem(departamento.PkidDepartamento!.Value))" />
                    </MudTooltip>
                    <MudTooltip Text="Eliminar departamento">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Visible="@CanDelete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => DeleteItem(departamento.PkidDepartamento!.Value))" />
                    </MudTooltip>
                </MudTd>
                <MudTd>@departamento.PkidDepartamento</MudTd>
                <MudTd>@departamento.DepartamentoNombre</MudTd>
                <MudTd>@departamento.EmpresaNombre</MudTd>
                <MudTd>
                    <MudBadge Color="@(departamento.DepartamentoActivo == true ? Color.Success : Color.Error)"
                              Variant="Variant.Filled"
                              Size="Size.Small">
                        @(departamento.DepartamentoActivo == true ? "Activo" : "Inactivo")
                    </MudBadge>
                </MudTd>
            </Row>
        </GenericTable>
    </MudContainer>
</AccessVerification>

@code {
    private GenericTable<DepartamentoResponse> table = null!;

    protected override string ModuleName => "configuracion";
    protected override string SubModuleName => "departamentos";

    protected override Type CreateDialogType => typeof(DepartamentoDialog);
    protected override Type EditDialogType => typeof(DepartamentoDialog);
    protected override Type DeleteDialogType => typeof(DeleteDialog<DepartamentoResponse>);

    protected override string GetDefaultSortLabel() => "DepartamentoNombre";

    protected override IEnumerable<object> MapToExcelData(IEnumerable<DepartamentoResponse> items)
    {
        return items.Select(d => new
        {
            ID = d.PkidDepartamento,
            Nombre = d.DepartamentoNombre,
            Empresa = d.EmpresaNombre,
            Estado = d.DepartamentoActivo == true ? "Activo" : "Inactivo"
        });
    }

    // Obtener el nombre del departamento para eliminar
    protected override async Task<string> GetItemNameForDelete(int id)
    {
        try
        {
            var response = await Service.GetByIdAsync(id);
            return response?.Data?.DepartamentoNombre ?? "el departamento";
        }
        catch
        {
            return "el departamento";
        }
    }

    // Recargar la tabla
    protected override async Task ReloadData()
    {
        if (table != null)
        {
            Console.WriteLine("🔄 Recargando tabla de departamentos...");
            await table.ReloadData();
            StateHasChanged();
        }
        else
        {
            Console.WriteLine("⚠️ table es null en ReloadData");
        }
    }

    // Personalizar la eliminación para usar el diálogo genérico
    protected override async Task DeleteItem(int id)
    {
        if (!CanDelete)
        {
            Snackbar.Add("No tienes permisos para eliminar", Severity.Warning);
            return;
        }

        var response = await Service.GetByIdAsync(id);
        var departamentoNombre = response?.Data?.DepartamentoNombre ?? "el departamento";

        var parameters = new DialogParameters
        {
            ["Id"] = id,
            ["ItemName"] = departamentoNombre,
            ["DeleteFunc"] = new Func<int, Task<bool>>(async (deleteId) =>
            {
                var deleteResponse = await Service.DeleteAsync(deleteId);
                if (deleteResponse?.Success == true)
                {
                    Snackbar.Add(deleteResponse.Message ?? "Departamento eliminado correctamente", Severity.Success);
                    await table.ReloadData();
                    return true;
                }
                else
                {
                    Snackbar.Add(deleteResponse?.Message ?? "Error al eliminar", Severity.Error);
                    return false;
                }
            })
        };

        var dialog = await DialogService.ShowAsync(DeleteDialogType, $"Eliminar {SubModuleName}", parameters,
            new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true });

        await dialog.Result;
    }
}