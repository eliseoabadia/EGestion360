@using MudBlazor
@typeparam TItem

<BaseCrudDialog TItem="TItem"
                @ref="dialog"
                MaxWidth="MaxWidth.Small"
                ActionColor="Color.Error"
                ActionIcon="@Icons.Material.Filled.Delete"
                ActionText="Eliminar"
                ProcessingText="Eliminando..."
                LoadingMessage="Cargando..."
                CanConfirm="!isDeleted"
                OnConfirm="Eliminar">

    <MudText Typo="Typo.h6" GutterBottom="true">¿Confirmar eliminación?</MudText>

    @if (!string.IsNullOrEmpty(ItemName))
    {
        <MudText Color="Color.Warning" Class="my-4">
            <strong>@ItemName</strong>
        </MudText>
    }

    <MudAlert Severity="Severity.Warning">
        Esta acción no se puede deshacer.
    </MudAlert>
</BaseCrudDialog>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public string? ItemName { get; set; }
    [Parameter] public Func<int, Task<bool>>? DeleteFunc { get; set; }

    private BaseCrudDialog<TItem> dialog = null!;
    private bool isDeleted = false;

    private async Task Eliminar()
    {
        Console.WriteLine("🗑️ Eliminar llamado");
        if (DeleteFunc == null)
        {
            Console.WriteLine("❌ DeleteFunc es null");
            return;
        }

        try
        {
            var result = await DeleteFunc(Id);
            Console.WriteLine($"📊 Resultado eliminación: {result}");

            if (result)
            {
                Console.WriteLine("✅ Eliminación exitosa, cerrando diálogo");
                isDeleted = true;
                dialog.Close(true);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error en Eliminar: {ex.Message}");
        }
    }
}